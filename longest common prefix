class Solution(object):
    def longestCommonPrefix(self, strs):
        p=strs[0]
        pl=len(p)
        for s in strs[1:]:
            while(p!=s[0:pl]):
                pl-=1
                if(pl==0):
                    return ""
                p=p[0:pl]
        return p


